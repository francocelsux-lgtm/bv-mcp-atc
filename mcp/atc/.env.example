# ─── ATC Credentials ───────────────────────────────────────────────────────────
ATC_EMAIL=tu_email@ejemplo.com
ATC_PASSWORD=tu_contraseña_atc

# URL de login (default: https://alquilatucancha.com/login)
ATC_LOGIN_URL=https://alquilatucancha.com/login

# URL completa de la agenda del club (la que ves en el navegador después de loguearte)
# Ejemplo: https://alquilatucancha.com/club/bella-vista-paddle/agenda
ATC_CLUB_SCHEDULE_URL=https://alquilatucancha.com/club/TU_SLUG/agenda

# Selectores CSS (sólo modificar si ATC cambia su HTML)
# ATC_SEL_EMAIL=input[type="email"]
# ATC_SEL_PASSWORD=input[type="password"]
# ATC_SEL_SUBMIT=button[type="submit"]

# Debug: guarda capturas y HTML en ./debug/
ATC_DEBUG=false
# ATC_DEBUG_DIR=./debug

# Ejecutable de Chromium alternativo (opcional, sólo si tenés Chromium custom)
# CHROMIUM_PATH=/usr/bin/chromium-browser

# ─── Google Sheets ─────────────────────────────────────────────────────────────
# Pega aquí el JSON completo de la Service Account (en una línea, sin saltos)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"..."}

# ID del Google Spreadsheet
GOOGLE_SPREADSHEET_ID=1lmMQdtU0Ps0mTlYf-jxycPnjE9L0OJmBZsOMb-PyU3M

# Nombre de la hoja destino (se crea si no existe)
GOOGLE_SHEET_NAME=ATC Reservas
