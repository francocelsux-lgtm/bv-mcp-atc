# ─── ATC Credentials ───────────────────────────────────────────────────────────
ATC_EMAIL=tu_email@ejemplo.com
ATC_PASSWORD=tu_contraseña_atc

# URL de login (default: https://atcsports.io/login)
ATC_LOGIN_URL=https://atcsports.io/login

# URL completa de la agenda del club (la que ves en el navegador después de loguearte)
# Bella Vista Paddle Club:
ATC_CLUB_SCHEDULE_URL=https://atcsports.io/club/bella-vista-paddle#!/app/grid

# Selectores CSS (sólo modificar si ATC cambia su HTML)
# ATC_SEL_EMAIL=input[type="email"]
# ATC_SEL_PASSWORD=input[type="password"]
# ATC_SEL_SUBMIT=button[type="submit"]

# Debug: guarda capturas y HTML en ./debug/
ATC_DEBUG=false
# ATC_DEBUG_DIR=./debug

# ID numérico del club en ATC (evita el warning al arrancar)
ATC_CLUB_ID=1629

# Ejecutable de Chromium alternativo (opcional, sólo si tenés Chromium custom)
# CHROMIUM_PATH=/usr/bin/chromium-browser

# ─── Google Sheets ─────────────────────────────────────────────────────────────
# OPCIÓN A (recomendada): OAuth2 Desktop App
# 1. Cloud Console → APIs & Services → Credentials → Create → OAuth 2.0 Client ID → Desktop app
# 2. Download JSON → pegá el contenido aquí en UNA línea
GOOGLE_OAUTH_CLIENT_JSON={"installed":{"client_id":"...","client_secret":"...","redirect_uris":["http://localhost"]}}

# OPCIÓN B: Service Account (solo si tu org permite crear claves)
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# ID del Google Spreadsheet
GOOGLE_SPREADSHEET_ID=1lmMQdtU0Ps0mTlYf-jxycPnjE9L0OJmBZsOMb-PyU3M

# Nombre de la hoja destino (se crea si no existe)
GOOGLE_SHEET_NAME=ATC Reservas
